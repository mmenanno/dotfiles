#!/usr/bin/env bash

# Nix Dotfiles Management Script
# Comprehensive tool for managing nix-darwin configuration

set -euo pipefail

# Get script directory and source shared utilities
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./shared
source "$SCRIPT_DIR/shared"

DOTFILES_DIR="/Users/michaelmenanno/dotfiles"
NIX_DIR="$DOTFILES_DIR/nix"

# Build the darwin-rebuild command as an array, falling back to nix run on fresh systems
get_darwin_rebuild_cmd() {
    if command -v darwin-rebuild >/dev/null 2>&1; then
        DARWIN_REBUILD_CMD=(darwin-rebuild)
    else
        DARWIN_REBUILD_CMD=(nix --extra-experimental-features "nix-command flakes" run nix-darwin --)
    fi
}

# Determine which darwinConfiguration to use based on hostname
get_config_name() {
    local work_hostname="${NIX_WORK_HOSTNAME:-}"
    # If env var not set, try reading from 1Password directly
    if [[ -z "$work_hostname" ]]; then
        work_hostname="$(op read "op://Nix/Work/hostname" 2>/dev/null || echo "")"
    fi
    if [[ -n "$work_hostname" ]]; then
        local current_hostname
        current_hostname="$(scutil --get LocalHostName 2>/dev/null || hostname -s)"
        if [[ "$current_hostname" == "$work_hostname" ]]; then
            echo "work_macbook"
            return
        fi
    fi
    echo "macbook_setup"
}

show_help() {
    cat << EOF
Nix Dotfiles Management Script

USAGE:
    nix <command> [options]

COMMANDS:
    up, apply, a       Apply configuration (darwin-rebuild switch)
                        -hm, --home-manager  Rebuild only Home Manager (faster)
                        -fm, --force-managed Revert managed files before applying
    check, c          Check flake for errors
    lint, l           Run code quality checks (statix, deadnix)
    update, u         Update flake dependencies
    pull, p           Pull latest dotfiles from remote
    edit, e           Open dotfiles in VS Code
    status, s         Show git status of dotfiles
    build, b          Build configuration without applying
    diff, d           Show what would change (dry-run)
    clean, cl         Clean old generations
    managed, m        Manage mutable config files (status/diff/revert/apply)
    pr                Create PR from current changes (opts: --merge, --title, --body)
    help, h           Show this help message

EXAMPLES:
    nix up            # Apply configuration
    nix up -hm        # Rebuild Home Manager only (faster for config changes)
    nix up -fm        # Revert managed files to Nix baseline, then apply
    nix c             # Check flake
    nix l             # Run linting checks
    nix u             # Update dependencies
    nix p             # Pull latest from remote
    nix e             # Edit in VS Code
    nix s             # Git status
    nix cl            # Clean old generations
    nix m             # Show mutable file status
    nix m d           # Diff mutable files against baseline
    nix m r claude    # Revert managed file to Nix version
    nix m a claude    # Apply app changes back into Nix module
    nix pr            # Create PR from current changes

EOF
}

check_flake() {
    log_info "Checking flake configuration..."
    if nix flake check "$NIX_DIR"; then
        log_success "Flake check passed"
        # Clean up any result symlinks from check
        if [[ -L "$NIX_DIR/result" ]]; then
            rm -f "$NIX_DIR/result"
        fi
        return 0
    else
        log_error "Flake check failed"
        return 1
    fi
}

lint_nix() {
    log_info "Running Nix code quality checks..."
    local failed=0

    # Run flake check without building
    log_info "1/3 Checking flake evaluation..."
    if nix flake check "$NIX_DIR" --no-build; then
        log_success "Flake evaluation passed"
    else
        log_error "Flake evaluation failed"
        failed=1
    fi

    # Run statix for static analysis
    log_info "2/3 Running statix (static analysis)..."
    if nix run nixpkgs#statix -- check "$NIX_DIR"; then
        log_success "Statix check passed"
    else
        log_error "Statix found issues"
        failed=1
    fi

    # Run deadnix to find dead code
    log_info "3/3 Running deadnix (dead code detection)..."
    if nix run nixpkgs#deadnix -- --fail "$NIX_DIR"; then
        log_success "Deadnix check passed"
    else
        log_error "Deadnix found unused code"
        failed=1
    fi

    # Clean up any result symlinks
    if [[ -L "$NIX_DIR/result" ]]; then
        rm -f "$NIX_DIR/result"
    fi

    if [[ $failed -eq 0 ]]; then
        log_success "All linting checks passed!"
        return 0
    else
        log_error "Some linting checks failed"
        return 1
    fi
}

update_flake() {
    log_info "Updating flake dependencies..."
    if nix flake update --flake "$NIX_DIR"; then
        log_success "Flake updated successfully"
        return 0
    else
        log_error "Flake update failed"
        return 1
    fi
}

apply_config() {
    local force=false
    local passthrough_args=()

    for arg in "$@"; do
        case "$arg" in
            --force-managed|--fm|-fm)
                force=true
                ;;
            *)
                passthrough_args+=("$arg")
                ;;
        esac
    done

    if [[ "$force" == true ]]; then
        log_info "Reverting managed files to Nix baseline before applying..."
        managed_revert all
    fi

    log_info "Applying nix-darwin configuration..."
    if "$SCRIPT_DIR/nixup-with-secrets" ${passthrough_args[@]+"${passthrough_args[@]}"}; then
        # nixup-with-secrets already prints success message
        return 0
    else
        log_error "Configuration apply failed"
        return 1
    fi
}

build_config() {
    log_info "Building nix-darwin configuration..."
    get_darwin_rebuild_cmd
    if "${DARWIN_REBUILD_CMD[@]}" build --flake "$NIX_DIR#$(get_config_name)"; then
        log_success "Configuration built successfully"
        # Clean up result symlink automatically
        if [[ -L "$NIX_DIR/result" ]]; then
            rm -f "$NIX_DIR/result"
            log_info "Cleaned up result symlink"
        fi
        return 0
    else
        log_error "Configuration build failed"
        return 1
    fi
}

show_diff() {
    log_info "Showing configuration diff (dry-run)..."
    get_darwin_rebuild_cmd
    "${DARWIN_REBUILD_CMD[@]}" build --flake "$NIX_DIR#$(get_config_name)" --dry-run
}

pull_dotfiles() {
    local default_branch
    default_branch=$(get_default_branch)
    local current_branch
    current_branch=$(git -C "$DOTFILES_DIR" branch --show-current)

    if [[ "$current_branch" != "$default_branch" ]]; then
        log_info "Currently on branch '$current_branch', switching to '$default_branch'..."
        if ! git -C "$DOTFILES_DIR" switch "$default_branch" 2>&1; then
            log_error "Cannot switch to $default_branch (uncommitted changes would be overwritten)"
            log_info "Commit or stash your changes first, then retry"
            return 1
        fi
        log_success "Switched to $default_branch"
    fi

    log_info "Pulling latest dotfiles from remote..."
    if git -C "$DOTFILES_DIR" pull; then
        log_success "Dotfiles updated successfully"
        return 0
    else
        log_error "Failed to pull dotfiles"
        return 1
    fi
}

edit_config() {
    log_info "Opening dotfiles in VS Code..."
    code "$DOTFILES_DIR"
}

show_status() {
    log_info "Git status of dotfiles:"
    git -C "$DOTFILES_DIR" status
}

clean_generations() {
    log_info "Cleaning old nix-darwin generations..."
    log_warning "This will remove old system generations. Continue? (y/N)"
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        log_info "Starting garbage collection..."

        # Start background process and show progress
        local temp_file
        temp_file=$(mktemp)
        sudo sh -c "nix-collect-garbage -d > \"$temp_file\" 2>&1" &
        local gc_pid=$!

        # Show progress while garbage collection runs
        local dots=0
        while kill -0 "$gc_pid" 2>/dev/null; do
            printf "\r%s[INFO]%s Garbage collection in progress" "${BLUE}" "${NC}"
            for ((i=0; i<dots; i++)); do printf "."; done
            printf "   "
            dots=$(( (dots + 1) % 4 ))
            sleep 0.5
        done

        # Wait for completion and get exit status
        wait "$gc_pid"
        local exit_code=$?

        # Clear the progress line
        printf "\r\033[K"

        if [[ $exit_code -eq 0 ]]; then
            local output
            output=$(cat "$temp_file")
            echo "$output"

            # Extract and highlight the freed space if available
            if echo "$output" | grep -q "freed"; then
                local freed
                freed=$(echo "$output" | grep -o "[0-9.]*\s*[KMGT]*iB freed" | tail -1)
                if [[ -n "$freed" ]]; then
                    log_success "Garbage collection completed - $freed"
                else
                    log_success "Garbage collection completed"
                fi
            else
                log_success "Garbage collection completed"
            fi
        else
            log_error "Garbage collection failed"
            cat "$temp_file"
            rm -f "$temp_file"
            return 1
        fi

        rm -f "$temp_file"
    else
        log_info "Cleaning cancelled"
    fi
}

# Determine default branch for origin (prefers gh if available)
get_default_branch() {
    local default_branch
    if command -v gh >/dev/null 2>&1; then
        # Use op plugin run to ensure 1Password plugin works in subshell
        default_branch=$(cd "$DOTFILES_DIR" && op plugin run -- gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null || true)
    fi
    if [[ -z "${default_branch:-}" ]]; then
        default_branch=$(git -C "$DOTFILES_DIR" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)
    fi
    if [[ -z "${default_branch:-}" ]]; then
        default_branch="main"
    fi
    echo "$default_branch"
}

# Create a PR for all current changes in the dotfiles repo
create_pr() {
    local auto_merge="false"
    local pr_title=""
    local pr_body=""

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --merge)
                auto_merge="true"
                shift
                ;;
            --title)
                pr_title=${2:-}
                shift 2 || true
                ;;
            --body)
                pr_body=${2:-}
                shift 2 || true
                ;;
            *)
                log_warning "Unknown option to pr: $1"
                shift
                ;;
        esac
    done

    if ! command -v git >/dev/null 2>&1; then
        log_error "git is required but not found in PATH"
        return 1
    fi

    if ! git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        log_error "DOTFILES_DIR is not a git repository: $DOTFILES_DIR"
        return 1
    fi

    # Check for changes
    if [[ -z $(git -C "$DOTFILES_DIR" status --porcelain) ]]; then
        log_warning "No changes detected in dotfiles; nothing to PR"
        return 0
    fi

    # Ensure origin exists
    if ! git -C "$DOTFILES_DIR" remote get-url origin >/dev/null 2>&1; then
        log_error "No 'origin' remote configured for dotfiles repo"
        return 1
    fi

    local default_branch
    default_branch=$(get_default_branch)

    log_info "Fetching latest from origin/$default_branch"
    git -C "$DOTFILES_DIR" fetch origin "$default_branch" >/dev/null 2>&1 || true

    # Create a unique branch name
    local ts
    ts=$(date +%Y%m%d-%H%M%S)
    local branch_name="auto/pr-${ts}"

    # Create branch off remote default branch if available, else current HEAD
    if git -C "$DOTFILES_DIR" show-ref --verify --quiet "refs/remotes/origin/${default_branch}"; then
        git -C "$DOTFILES_DIR" checkout -B "$branch_name" "origin/${default_branch}"
    else
        git -C "$DOTFILES_DIR" checkout -b "$branch_name"
    fi

    # Stage and commit all changes
    git -C "$DOTFILES_DIR" add -A
    if git -C "$DOTFILES_DIR" diff --cached --quiet; then
        log_warning "Nothing staged after add; aborting PR creation"
        return 0
    fi

    local commit_msg
    if [[ -n "$pr_title" ]]; then
        commit_msg="$pr_title"
    else
        commit_msg="chore: dotfiles update via nx pr (${ts})"
    fi
    git -C "$DOTFILES_DIR" commit -m "$commit_msg"

    # Push branch
    log_info "Pushing branch $branch_name to origin"
    git -C "$DOTFILES_DIR" push -u origin "$branch_name"

    # Create PR (prefer gh)
    if command -v gh >/dev/null 2>&1; then
        local gh_args=(pr create --base "$default_branch" --head "$branch_name" --title "${pr_title:-$commit_msg}")
        if [[ -n "$pr_body" ]]; then
            gh_args+=(--body "$pr_body")
        else
            gh_args+=(--body "Automated PR from nx pr on ${ts}.")
        fi

        log_info "Creating PR via GitHub CLI"
        # Use op plugin run to ensure 1Password plugin works in subshell
        if (cd "$DOTFILES_DIR" && op plugin run -- gh "${gh_args[@]}") >/dev/null; then
            log_success "PR created successfully"
        else
            log_error "Failed to create PR via gh"
            return 1
        fi

        if [[ "$auto_merge" == "true" ]]; then
            # Enable auto-merge - PR will merge automatically when all checks pass
            log_info "Enabling auto-merge (will merge automatically when checks pass)"
            if (cd "$DOTFILES_DIR" && op plugin run -- gh pr merge "$branch_name" --auto --squash 2>/dev/null); then
                log_success "Auto-merge enabled with squash"
            elif (cd "$DOTFILES_DIR" && op plugin run -- gh pr merge "$branch_name" --auto --merge 2>/dev/null); then
                log_success "Auto-merge enabled with merge commit"
            else
                log_warning "Could not enable auto-merge. Repository may require branch protection rules or admin access."
            fi
        fi
    else
        log_warning "GitHub CLI (gh) not found; PR not created automatically"
        log_info "Branch pushed: $branch_name. Create a PR on your hosting provider."
    fi

    return 0
}

# --- Mutable file management ---

# Compare two files semantically for JSON, falling back to byte comparison.
# Returns 0 if equal, 1 if different.
json_files_equal() {
    local file_a="$1" file_b="$2"
    local norm_a norm_b
    if norm_a=$(jq -S . "$file_a" 2>/dev/null) && norm_b=$(jq -S . "$file_b" 2>/dev/null); then
        [[ "$norm_a" == "$norm_b" ]]
    else
        cmp -s "$file_a" "$file_b"
    fi
}
# Must match mutablePaths in nix/modules/home/mutable-files.nix
# Ordered list of shorthand names (used for iteration order)
MANAGED_NAMES=(claude op vscode vsmcp)
BASELINE_DIR="$HOME/.local/share/nix-managed-baselines"

# Shorthand -> full path mapping
declare -A MANAGED_FILES=(
    [claude]=".claude/settings.json"
    [op]=".config/op/plugins.sh"
    [vscode]="Library/Application Support/Code/User/settings.json"
    [vsmcp]="Library/Application Support/Code/User/mcp.json"
)

# Shorthand -> Nix source file mapping
declare -A MANAGED_NIX_SOURCES=(
    [claude]="nix/modules/home/claude.nix"
    [op]="nix/modules/home/onepassword.nix"
    [vscode]="nix/modules/home/vscode.nix"
    [vsmcp]="nix/modules/home/vscode.nix"
)

# Resolve a filter to a list of shorthand names
# Sets RESOLVED_NAMES array
resolve_managed_filter() {
    local filter="${*}"
    RESOLVED_NAMES=()

    if [ -z "$filter" ] || [ "$filter" = "all" ]; then
        RESOLVED_NAMES=("${MANAGED_NAMES[@]}")
        return 0
    fi

    # Check for exact shorthand match
    if [[ -n "${MANAGED_FILES[$filter]+x}" ]]; then
        RESOLVED_NAMES=("$filter")
        return 0
    fi

    # Substring match against paths
    for name in "${MANAGED_NAMES[@]}"; do
        local path="${MANAGED_FILES[$name]}"
        if [[ "$path" == *"$filter"* ]]; then
            RESOLVED_NAMES+=("$name")
        fi
    done

    if [ ${#RESOLVED_NAMES[@]} -eq 0 ]; then
        return 1
    fi
    return 0
}

managed_show_names() {
    echo -e "\n${DIM}Available names:${NC}"
    for name in "${MANAGED_NAMES[@]}"; do
        echo -e "  ${CYAN}${name}${NC}  ${DIM}${MANAGED_FILES[$name]}${NC}"
    done
    echo -e "  ${CYAN}all${NC}   ${DIM}all managed files${NC}"
}

managed_status() {
    echo ""
    echo -e "${BOLD}Mutable Config Files${NC}"
    echo ""
    for name in "${MANAGED_NAMES[@]}"; do
        local path="${MANAGED_FILES[$name]}"
        local target="$HOME/$path"
        local baseline="$BASELINE_DIR/$path"
        local icon color label

        if [ -L "$target" ]; then
            icon="~" color="$YELLOW" label="symlink (not yet converted)"
        elif [ ! -f "$target" ]; then
            icon="x" color="$RED" label="missing"
        elif [ ! -f "$baseline" ]; then
            icon="?" color="$YELLOW" label="no baseline"
        elif json_files_equal "$target" "$baseline"; then
            icon="✓" color="$GREEN" label="clean"
        else
            icon="!" color="$YELLOW" label="modified by app"
        fi

        echo -e "  ${color}${icon}${NC}  ${CYAN}${name}${NC}  ${DIM}${path}${NC}  ${color}${label}${NC}"
    done
    echo ""
}

managed_diff() {
    if ! resolve_managed_filter "$@"; then
        log_error "No managed file matching: $*"
        managed_show_names
        return 1
    fi

    for name in "${RESOLVED_NAMES[@]}"; do
        local path="${MANAGED_FILES[$name]}"
        local target="$HOME/$path"
        local baseline="$BASELINE_DIR/$path"

        if [ ! -f "$baseline" ]; then
            echo -e "  ${YELLOW}?${NC}  ${CYAN}${name}${NC}  ${YELLOW}no baseline${NC}"
            continue
        fi
        if [ ! -f "$target" ]; then
            echo -e "  ${RED}x${NC}  ${CYAN}${name}${NC}  ${RED}missing${NC}"
            continue
        fi

        # Normalize JSON files to ignore key ordering differences
        local norm_baseline norm_target
        norm_baseline=$(mktemp)
        norm_target=$(mktemp)

        jq -S . "$baseline" > "$norm_baseline" 2>/dev/null || cp "$baseline" "$norm_baseline"
        jq -S . "$target" > "$norm_target" 2>/dev/null || cp "$target" "$norm_target"

        if cmp -s "$norm_baseline" "$norm_target"; then
            rm -f "$norm_baseline" "$norm_target"
            echo -e "  ${GREEN}✓${NC}  ${CYAN}${name}${NC}  ${GREEN}no changes${NC}"
        else
            echo -e "  ${YELLOW}!${NC}  ${CYAN}${name}${NC}  ${YELLOW}modified by app${NC}"
            code --diff "$norm_baseline" "$norm_target"
            # Don't delete temp files — code --diff is async and needs them
        fi
    done
}

managed_revert() {
    if ! resolve_managed_filter "${@:-all}"; then
        log_error "No managed file matching: $*"
        managed_show_names
        return 1
    fi

    for name in "${RESOLVED_NAMES[@]}"; do
        local path="${MANAGED_FILES[$name]}"
        local target="$HOME/$path"
        local baseline="$BASELINE_DIR/$path"

        if [ ! -f "$baseline" ]; then
            log_error "No baseline for $name: $path"
            continue
        fi

        cp "$baseline" "$target"
        chmod 644 "$target"
        log_success "Reverted to Nix version for: ${name} ($path)"
    done
}

managed_apply() {
    if ! command -v claude >/dev/null 2>&1; then
        log_error "claude CLI is required but not found in PATH"
        return 1
    fi

    if ! resolve_managed_filter "${@:-all}"; then
        log_error "No managed file matching: $*"
        managed_show_names
        return 1
    fi

    local applied=0
    for name in "${RESOLVED_NAMES[@]}"; do
        local path="${MANAGED_FILES[$name]}"
        local target="$HOME/$path"
        local baseline="$BASELINE_DIR/$path"
        local nix_source="${MANAGED_NIX_SOURCES[$name]}"

        if [ ! -f "$baseline" ]; then
            log_warning "No baseline for $name — skipping"
            continue
        fi
        if [ ! -f "$target" ]; then
            log_warning "Target missing for $name — skipping"
            continue
        fi
        if cmp -s "$target" "$baseline"; then
            log_info "$name is clean — nothing to apply"
            continue
        fi

        log_info "Applying changes from $name into $nix_source..."

        local file_diff
        file_diff=$(diff -u "$baseline" "$target" || true)

        local prompt
        prompt="The managed config file '${path}' has been modified by the application at runtime.
Here is the diff between the Nix baseline and the current runtime version:

\`\`\`diff
${file_diff}
\`\`\`

The Nix module that generates this file is at: ${nix_source}

Please update ONLY the relevant section in the Nix module to incorporate these changes.
Preserve the existing code style and formatting. Do not modify any other parts of the file.
You may reorder sections to match the preferred order that the application is ordering them in."

        if echo "$prompt" | claude -p --allowedTools "Read,Edit" --add-dir "$DOTFILES_DIR"; then
            log_success "Applied changes for: ${name} ($path)"
            applied=$((applied + 1))
        else
            log_error "Failed to apply changes for: ${name}"
        fi
    done

    if [ $applied -gt 0 ]; then
        echo ""
        log_info "Run 'nx check' to validate the updated flake."
    fi
}

# Main command handling
case "${1:-help}" in
    up|apply|a)
        shift || true
        apply_config "$@"
        ;;
    check|c)
        check_flake
        ;;
    lint|l)
        lint_nix
        ;;
    update|u)
        update_flake
        ;;
    pull|p)
        pull_dotfiles
        ;;
    edit|e)
        edit_config
        ;;
    status|s)
        show_status
        ;;
    build|b)
        build_config
        ;;
    diff|d)
        show_diff
        ;;
    clean|cl)
        clean_generations
        ;;
    managed|m)
        shift || true
        case "${1:-}" in
            diff|d)
                shift || true
                managed_diff "$@"
                ;;
            revert|r)
                shift || true
                managed_revert "$@"
                ;;
            apply|a)
                shift || true
                managed_apply "$@"
                ;;
            *)
                managed_status
                ;;
        esac
        ;;
    pr)
        shift || true
        create_pr "$@"
        ;;
    help|h|--help|-h)
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
